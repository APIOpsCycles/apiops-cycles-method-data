{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": {
    "type": "array",
    "items": {
      "type": "object",
      "required": ["stakeholder", "involvement"],
      "additionalProperties": false,
      "properties": {
        "stakeholder": {"type": "string"},
        "involvement": {
          "type": "string",
          "enum": ["lead", "core", "consulted"]
        }
      }
    }
  }
}
