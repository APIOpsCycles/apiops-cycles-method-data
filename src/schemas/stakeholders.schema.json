{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["stakeholders"],
  "additionalProperties": false,
  "properties": {
    "stakeholders": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "description"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string"},
          "title": {"type": "string"},
          "description": {"type": "string"}
        }
      }
    }
  }
}
